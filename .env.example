# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret

# Supabase Postgres connection string (required)
# Also used to auto-apply migrations during Vercel production builds — use a
# DIRECT connection (db.[ref].supabase.co:5432), not the transaction pooler (6543).
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Optional: separate connection string used ONLY for build-time migrations
# (falls back to SUPABASE_DB_URL). Handy if the app itself runs via the pooler.
# SUPABASE_DB_MIGRATION_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Optional: force build-time migrations to run outside Vercel production
# (by default they only run when VERCEL_ENV=production).
# FORCE_DB_MIGRATE=true

# Supabase JS client (required for most app queries)
# Optional if derivable from SUPABASE_DB_URL (db.[ref].supabase.co or pooler postgres.[ref] user)
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# SUPABASE_PROJECT_REF=[YOUR-PROJECT-REF]
# Dashboard → Settings → API → service_role (server-side only, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Regenerate typed client after schema changes: pnpm supabase:types

# AI Provider Keys
XAI_API_KEY=your-xai-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Brave Search (optional, for web search tool)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# WhatsApp worker (independent service that drains CadreWhatsAppMessage queue)
WHATSAPP_WORKER_API_KEY=your-whatsapp-worker-api-key

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your-blob-token

# Optional: Set to current Unix timestamp to invalidate all sessions
# AUTH_SESSION_EPOCH=

# Optional: Default election ID
# CURRENT_ELECTION_ID=172LS2024

# Optional: Election ID used by the SIR module to resolve Part No / Serial No
# SIR_ELECTION_ID=172VS2024

# Web Push (generate keys with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@bridgeit.in
